rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    function isEditor() {
      return request.auth != null
        && (request.auth.token.admin == true || request.auth.token.editor == true);
    }

    // posts: 공개 읽기, editor/admin만 쓰기
    match /posts/{postId} {
      allow read: if true;
      allow create, update: if isEditor();
      allow delete: if isEditor();
    }

    // categories: 공개 읽기, editor/admin만 쓰기
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // users: 본인 문서만 읽기/쓰기
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // 검사 결과 히스토리 (본인만)
      match /testResults/{resultId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 데일리 트래킹 (기분/수면/스트레스 등)
      match /dailyLogs/{dateKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 자가 돌봄 도구 세션 (호흡/CBT/감사/마음챙김)
      match /practiceSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // drafts: Cloud Functions(admin SDK)로만 접근, 클라이언트 차단
    match /drafts/{draftId} {
      allow read, write: if false;
    }

    // adminConfig: Cloud Functions(admin SDK)로만 접근, 클라이언트 차단
    // 관리자는 callable function(getAutoPublishConfig/updateAutoPublishConfig)을 통해서만 접근
    match /adminConfig/{docId} {
      allow read, write: if false;
    }
  }
}

rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    function isEditor() {
      return request.auth != null
        && (request.auth.token.admin == true || request.auth.token.editor == true);
    }

    // posts: 공개 읽기, editor/admin만 쓰기
    // 예외: 누구나 viewCount만 +1 증가 가능 (조회수 카운터)
    match /posts/{postId} {
      allow read: if true;
      allow create: if isEditor();
      allow update: if isEditor()
        || (
          // viewCount 필드만 변경되고, 값이 정확히 +1 증가하는 경우만 허용
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
          && request.resource.data.viewCount is int
          && (
            (resource.data.viewCount is int && request.resource.data.viewCount == resource.data.viewCount + 1)
            || (!('viewCount' in resource.data) && request.resource.data.viewCount == 1)
          )
        );
      allow delete: if isEditor();
    }

    // categories: 공개 읽기, editor/admin만 쓰기
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // users: 본인 문서만 읽기/쓰기
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // 검사 결과 히스토리 (본인만)
      match /testResults/{resultId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 데일리 트래킹 (기분/수면/스트레스 등)
      match /dailyLogs/{dateKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 자가 돌봄 도구 세션 (호흡/CBT/감사/마음챙김)
      match /practiceSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // drafts: Cloud Functions(admin SDK)로만 접근, 클라이언트 차단
    match /drafts/{draftId} {
      allow read, write: if false;
    }

    // adminConfig: Cloud Functions(admin SDK)로만 접근, 클라이언트 차단
    // 관리자는 callable function(getAutoPublishConfig/updateAutoPublishConfig)을 통해서만 접근
    match /adminConfig/{docId} {
      allow read, write: if false;
    }

    // testStats: 집계 통계(개인정보 없음) - 공개 읽기(익명 수검자 IQ 환산 등), 쓰기는 Cloud Function만
    match /testStats/{testType} {
      allow read: if true;
      allow write: if false;
    }

    // anonTestResults: 비로그인 수검자의 익명 점수 - 규준(표준화) 통계용.
    // 제출만 가능, 읽기/수정/삭제 차단. 트리거가 testStats로 집계.
    match /anonTestResults/{docId} {
      allow create: if request.resource.data.type is string
        && request.resource.data.type.size() >= 1
        && request.resource.data.type.size() <= 40
        && request.resource.data.result is map;
      allow read, update, delete: if false;
    }

    // feedback: 개선사항 요청 - 누구나(비로그인 포함) 제출만 가능, 읽기/수정/삭제 차단
    // 관리자는 Firebase 콘솔 또는 admin SDK로만 열람
    match /feedback/{docId} {
      allow create: if request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 2000;
      allow read, update, delete: if false;
    }
  }
}
